// Enums shared with Rust. Order/names must match Rust definitions.

export enum RuleTypeUi {
    custom,
    case-size,
    purge,
    add-number,
    add-text,
    replace,
    trim,
    normalize,
}

export enum RulePlaceUi {
    none-p,
    extension,
    name-p,
    extension-and-name,
    before-extension,
    after-extension,
    before-name,
    after-name,
    from-name-start,
    from-name-end-reverse,
    from-extension-start,
    from-extension-end-reverse,
}

export enum DirFileTypeUi {
    file-t,
    directory-t,
}

export enum NotebookTab {
    custom,
    case-size,
    purge,
    add-number,
    add-text,
    replace,
    trim,
    normalize,
}

export enum SelectMode {
    select-all,
    unselect-all,
    reverse,
    select-custom,
    unselect-custom,
    select-changed,
    unselect-changed,
}

export enum LoadDirection {
    load,
    save,
    delete,
}

export enum SortColumn {
    none,
    type-c,
    current,
    future,
    path,
}

export struct FileRow {
    selected: bool,
    dir_type: DirFileTypeUi,
    current_name: string,
    future_name: string,
    path: string,
    size_text: string,
    date_text: string,
}

export struct RuleRow {
    selected: bool,
    rule_type_text: string,
    usage_text: string,
    description: string,
}

export struct RuleSetEntry {
    name: string,
}

