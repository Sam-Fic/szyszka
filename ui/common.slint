export global Settings {
    in-out property <bool> dark_theme: true;
    in-out property <string> selected_language: "English";
    in-out property <[string]> available_languages: [
        "English",
        "Polski (Polish)",
        "Français (French)",
        "Italiano (Italian)",
        "Русский (Russian)",
        "український (Ukrainian)",
        "Česky (Czech)",
        "Deutsch (German)",
        "やまと (Japanese)",
        "Português (Portuguese)",
        "简体中文 (Simplified Chinese)",
        "Español (Spanish)",
        "Swedish (Svenska)",
    ];
}

export global EditorState {
    in-out property <NotebookTab> current_tab: NotebookTab.custom;
    in-out property <string> example_before_text: "Gżegżółka.Txt";
    in-out property <string> example_after_text: "Gżegżółka.Txt";

    in-out property <string> custom_text: "FILE_$(N).$(EXT)";

    in-out property <bool> case_lowercase: true;
    in-out property <RulePlaceUi> case_place: RulePlaceUi.name-p;

    in-out property <RulePlaceUi> purge_place: RulePlaceUi.name-p;

    in-out property <RulePlaceUi> add_number_place: RulePlaceUi.before-name;
    in-out property <string> add_number_start: "0";
    in-out property <string> add_number_step: "1";
    in-out property <string> add_number_zeros: "0";

    in-out property <RulePlaceUi> add_text_place: RulePlaceUi.before-name;
    in-out property <string> add_text_text: "";

    in-out property <RulePlaceUi> replace_place: RulePlaceUi.name-p;
    in-out property <bool> replace_case_sensitive: false;
    in-out property <bool> replace_use_regex: false;
    in-out property <bool> replace_all_occurrences: true;
    in-out property <string> replace_text_to_find: "";
    in-out property <string> replace_text_to_replace: "";
    in-out property <bool> replace_invalid_regex: false;
    in-out property <string> replace_captures_text: "";

    in-out property <RulePlaceUi> trim_place: RulePlaceUi.from-name-start;
    in-out property <bool> trim_case_sensitive: false;
    in-out property <string> trim_text: "";

    in-out property <bool> normalize_full: true;
}

export global ProgressState {
    in-out property <bool> visible: false;
    in-out property <string> title: "";
    in-out property <string> message: "";
    in-out property <int> current: 0;
    in-out property <int> total: 0;
    in-out property <bool> indeterminate: true;
}

export global GuiState {
    in-out property <bool> rule_editor_open: false;
    in-out property <bool> settings_open: false;
    in-out property <bool> select_popup_open: false;
    in-out property <bool> load_popup_open: false;
    in-out property <bool> confirm_dialog_open: false;
    in-out property <bool> outdated_warning_open: false;
    in-out property <bool> results_dialog_open: false;
    in-out property <bool> message_dialog_open: false;
    in-out property <bool> select_custom_dialog_open: false;
    in-out property <bool> save_rule_dialog_open: false;
    in-out property <bool> add_files_dialog_open: false;
    in-out property <bool> add_folders_dialog_open: false;

    in-out property <string> message_dialog_title: "";
    in-out property <string> message_dialog_text: "";

    in-out property <int> file_count: 0;
    in-out property <int> rule_count: 0;
    in-out property <bool> results_outdated: false;

    in-out property <int> properly_renamed: 0;
    in-out property <int> ignored_count: 0;
    in-out property <string> failed_text: "";
    in-out property <int> failed_total: 0;
    in-out property <int> failed_page: 0;
    in-out property <int> failed_pages: 0;

    in-out property <string> select_custom_text: "";
    in-out property <bool> select_custom_select_dirs: true;
    in-out property <int> select_custom_mode_index: 0;

    in-out property <string> save_rule_name: "";
    in-out property <string> existing_rule_set_names: "";

    in-out property <bool> add_folder_scan_inside: false;
    in-out property <bool> add_folder_ignore_folders: false;
    in-out property <[string]> add_folder_picked_paths: [];

    in-out property <SortColumn> sort_column: SortColumn.none;
    in-out property <bool> sort_descending: false;

    in-out property <length> col_type_width: 50px;
    in-out property <length> col_current_width: 240px;
    in-out property <length> col_future_width: 240px;

    in-out property <int> last_file_anchor_idx: -1;
    in-out property <int> last_rule_anchor_idx: -1;
}

export global Callabler {
    callback request-add-files();
    callback request-pick-folders();
    callback confirm-add-folders(bool /*scan_inside*/, bool /*ignore_folders*/);
    callback remove-selected-files();
    callback select-action(SelectMode);
    callback select-custom-apply(string /*pattern*/, bool /*include_dirs*/, int /*mode_index*/, bool /*select_else_unselect*/);
    callback results-move-up();
    callback results-move-down();
    callback results-set-page(int /*page*/);
    callback results-copy-errors();
    callback update-names();
    callback start-renaming();
    callback confirm-renaming();

    callback open-rule-editor(int /*edit_index_or_-1*/);
    callback close-rule-editor();
    callback rule-editor-add();
    callback rule-editor-update-example();
    callback rule-remove(int);
    callback rule-move-up();
    callback rule-move-down();

    callback rule-set-save(string /*name*/);
    callback rule-set-load(int /*index*/);
    callback rule-set-delete(int /*index*/);
    callback request-load-rule-sets();
    in-out property <[RuleSetEntry]> saved_rule_sets: [];

    callback custom-rule-save(string);
    callback custom-rule-load(int);
    callback custom-rule-delete(int);
    in-out property <[string]> saved_custom_rules: [];

    callback set-dark-theme(bool);
    callback set-language(string);
    callback open-rules-file();
    callback open-custom-texts-file();
    callback open-config-dir();
    callback open-log-folder();

    callback set-rule-selected(int, bool);

    // Row-click selection (krokiet-style):
    //   plain click  -> select-only (clears others, selects this)
    //   ctrl+click   -> toggle      (flips this row)
    //   shift+click  -> range       (selects every row between anchor and idx)
    callback file-row-click-select(int /*idx*/);
    callback file-row-click-toggle(int /*idx*/);
    callback file-row-click-range(int /*anchor*/, int /*idx*/);
    callback rule-row-click-select(int /*idx*/);
    callback rule-row-click-toggle(int /*idx*/);
    callback rule-row-click-range(int /*anchor*/, int /*idx*/);

    callback sort-files(SortColumn);
    callback open-file(int);
    callback open-file-folder(int);

    pure callback filter-number(string) -> string;
}
