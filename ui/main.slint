import { Button, LineEdit, CheckBox, ComboBox, ScrollView, GroupBox, HorizontalBox, VerticalBox, ListView, StandardButton, Palette } from "std-widgets.slint";
import { Translations, Settings, Callabler, GuiState, EditorState, ProgressState, FileRow, RuleRow, RuleSetEntry, SelectMode, DirFileTypeUi, NotebookTab, RuleTypeUi, RulePlaceUi, SortColumn } from "common.slint";
import { RuleEditorPanel } from "rule_editor.slint";

component SortHeaderCell inherits Rectangle {
    in property <string> label_text;
    in property <SortColumn> column;
    in property <bool> resizable: true;
    in-out property <length> col_width;
    callback width-changed(length);

    background: ta.has-hover ? Palette.alternate-background : transparent;

    ta := TouchArea {
        clicked => { Callabler.sort-files(root.column); }
    }

    Text {
        x: 6px;
        width: root.width - 10px;
        text: root.label_text;
        vertical-alignment: center;
        horizontal-alignment: center;
        font-weight: 700;
        overflow: elide;
    }

    if root.resizable : Rectangle {
        x: root.width - 1px;
        y: 4px;
        width: 1px;
        height: root.height - 8px;
        background: Palette.border;

        handle := TouchArea {
            mouse-cursor: ew-resize;
            width: 8px;
            x: (parent.width - self.width) / 2;
            moved => {
                if self.pressed {
                    root.width-changed(max(40px, root.col_width + (self.mouse-x - self.pressed-x)));
                }
            }
        }
    }
}

export { Translations, Settings, Callabler, GuiState, EditorState, ProgressState, RuleTypeUi, RulePlaceUi, NotebookTab, DirFileTypeUi, SelectMode }

export component MainWindow inherits Window {
    title: "Szyszka";
    preferred-width: 1100px;
    preferred-height: 720px;
    min-width: 800px;
    min-height: 600px;

    in property <[FileRow]> files: [];
    in property <[RuleRow]> rules: [];

    property <bool> theme_sync: Settings.dark_theme;
    changed theme_sync => { Palette.color-scheme = self.theme_sync ? ColorScheme.dark : ColorScheme.light; }
    init => { Palette.color-scheme = Settings.dark_theme ? ColorScheme.dark : ColorScheme.light; }

    // Top bar
    VerticalBox {
        padding: 8px;
        spacing: 6px;

        // Header bar
        HorizontalLayout {
            spacing: 6px;
            Button {
                text: Translations.upper_start_renaming_button;
                primary: true;
                enabled: GuiState.file_count > 0 && GuiState.rule_count > 0;
                clicked => { Callabler.start-renaming(); }
            }
            Rectangle { horizontal-stretch: 1; }
            Button {
                icon: @image-url("../icons/szy_settings.svg");
                colorize-icon: true;
                clicked => { GuiState.settings_open = !GuiState.settings_open; }
            }
        }

        // Files section label
        Text {
            text: GuiState.file_count == 0
                ? Translations.upper_files_folders_label
                : (GuiState.results_outdated
                    ? Translations.upper_files_folders_label + " (" + GuiState.file_count + ") - UPDATE REQUIRED"
                    : Translations.upper_files_folders_label + " (" + GuiState.file_count + ") - up to date");
            color: GuiState.file_count > 0 && GuiState.results_outdated ? red : Palette.foreground;
            font-weight: 600;
        }

        // Files area
        HorizontalLayout {
            spacing: 6px;
            min-height: 200px;
            vertical-stretch: 1;

            // File list
            Rectangle {
                background: Palette.alternate-background;
                border-radius: 6px;
                border-width: 1px;
                border-color: Palette.border;
                horizontal-stretch: 1;

                VerticalLayout {
                    // header
                    Rectangle {
                        height: 28px;
                        background: Palette.control-background;
                        border-radius: 6px;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 0px;
                            SortHeaderCell {
                                width: GuiState.col_type_width;
                                col_width: GuiState.col_type_width;
                                label_text: Translations.tree_view_upper_column_type;
                                column: SortColumn.type-c;
                                width-changed(w) => { GuiState.col_type_width = w; }
                            }
                            SortHeaderCell {
                                width: GuiState.col_current_width;
                                col_width: GuiState.col_current_width;
                                label_text: Translations.tree_view_upper_column_current_name;
                                column: SortColumn.current;
                                width-changed(w) => { GuiState.col_current_width = w; }
                            }
                            SortHeaderCell {
                                width: GuiState.col_future_width;
                                col_width: GuiState.col_future_width;
                                label_text: Translations.tree_view_upper_column_future_name;
                                column: SortColumn.future;
                                width-changed(w) => { GuiState.col_future_width = w; }
                            }
                            SortHeaderCell {
                                horizontal-stretch: 1;
                                resizable: false;
                                label_text: Translations.tree_view_upper_column_path;
                                column: SortColumn.path;
                            }
                        }
                    }
                    ListView {
                        vertical-stretch: 1;
                        for row[idx] in root.files : Rectangle {
                            height: 26px;
                            background: row.selected ? Palette.accent-background : (mod(idx, 2) == 0 ? Palette.alternate-background : Palette.background);
                            ta := TouchArea {
                                double-clicked => {
                                    Callabler.open-file(idx);
                                }
                                pointer-event(event) => {
                                    if event.button == PointerEventButton.right && event.kind == PointerEventKind.up {
                                        Callabler.open-file-folder(idx);
                                    } else if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                                        if event.modifiers.control {
                                            GuiState.last_file_anchor_idx = idx;
                                            Callabler.file-row-click-toggle(idx);
                                        } else if event.modifiers.shift {
                                            if GuiState.last_file_anchor_idx == -1 {
                                                GuiState.last_file_anchor_idx = idx;
                                            }
                                            Callabler.file-row-click-range(GuiState.last_file_anchor_idx, idx);
                                        } else {
                                            GuiState.last_file_anchor_idx = idx;
                                            Callabler.file-row-click-select(idx);
                                        }
                                    }
                                }
                            }
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 0px;
                                Rectangle {
                                    width: GuiState.col_type_width;
                                    clip: true;
                                    Text {
                                        x: 6px;
                                        width: parent.width - 10px;
                                        text: row.dir_type == DirFileTypeUi.directory-t ? "Dir" : "File";
                                        vertical-alignment: center;
                                        color: row.selected ? Palette.accent-foreground : Palette.foreground;
                                        overflow: elide;
                                    }
                                }
                                Rectangle {
                                    width: GuiState.col_current_width;
                                    clip: true;
                                    Text {
                                        x: 6px;
                                        width: parent.width - 10px;
                                        text: row.current_name;
                                        vertical-alignment: center;
                                        color: row.selected ? Palette.accent-foreground : Palette.foreground;
                                        overflow: elide;
                                    }
                                }
                                Rectangle {
                                    width: GuiState.col_future_width;
                                    clip: true;
                                    Text {
                                        x: 6px;
                                        width: parent.width - 10px;
                                        text: row.future_name;
                                        vertical-alignment: center;
                                        color: row.future_name != row.current_name ? #2e8b57 : (row.selected ? Palette.accent-foreground : Palette.foreground);
                                        overflow: elide;
                                    }
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    clip: true;
                                    Text {
                                        x: 6px;
                                        width: parent.width - 10px;
                                        text: row.path;
                                        vertical-alignment: center;
                                        color: row.selected ? Palette.accent-foreground : Palette.foreground;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Right action buttons
            VerticalLayout {
                spacing: 4px;
                width: 180px;
                Button { text: Translations.upper_add_files_button; clicked => { Callabler.request-add-files(); } }
                Button { text: Translations.upper_add_folders_button; clicked => { Callabler.request-pick-folders(); } }
                Button { text: Translations.upper_remove_selection_button; clicked => { Callabler.remove-selected-files(); } }
                Button {
                    text: Translations.upper_select_popup_button;
                    icon: @image-url("../icons/szy_select.svg");
                    colorize-icon: true;
                    clicked => { GuiState.select_popup_open = !GuiState.select_popup_open; }
                }
                Button { text: Translations.upper_update_names_button; clicked => { Callabler.update-names(); } }
                Button {
                    text: Translations.upper_results_one_up_button;
                    icon: @image-url("../icons/szy_up.svg");
                    colorize-icon: true;
                    clicked => { Callabler.results-move-up(); }
                }
                Button {
                    text: Translations.upper_results_one_down_button;
                    icon: @image-url("../icons/szy_down.svg");
                    colorize-icon: true;
                    clicked => { Callabler.results-move-down(); }
                }
                Rectangle { vertical-stretch: 1; }
            }
        }

        // Rules section label
        Text {
            text: Translations.bottom_rule_label_rules;
            font-weight: 600;
        }

        // Rules area
        HorizontalLayout {
            spacing: 6px;
            min-height: 150px;
            vertical-stretch: 1;

            // Rules buttons
            VerticalLayout {
                spacing: 4px;
                width: 180px;
                Button { text: Translations.bottom_rule_add_button; clicked => { Callabler.open-rule-editor(-1); } }
                Button { text: Translations.bottom_rule_edit_button; clicked => {
                    // find first selected rule index
                    Callabler.open-rule-editor(0);
                } }
                Button { text: Translations.bottom_rule_remove_button; clicked => {
                    Callabler.rule-remove(-1); // -1 means remove all selected
                } }
                Button {
                    text: Translations.bottom_rule_one_up_button;
                    icon: @image-url("../icons/szy_up.svg");
                    colorize-icon: true;
                    clicked => { Callabler.rule-move-up(); }
                }
                Button {
                    text: Translations.bottom_rule_one_down_button;
                    icon: @image-url("../icons/szy_down.svg");
                    colorize-icon: true;
                    clicked => { Callabler.rule-move-down(); }
                }
                Button {
                    text: Translations.bottom_rule_load_rules_button;
                    enabled: Callabler.saved_rule_sets.length > 0;
                    clicked => { Callabler.request-load-rule-sets(); GuiState.load_popup_open = !GuiState.load_popup_open; }
                }
                Button {
                    text: Translations.bottom_rule_save_rules_button;
                    enabled: GuiState.rule_count > 0;
                    clicked => { GuiState.save_rule_dialog_open = true; }
                }
                Rectangle { vertical-stretch: 1; }
            }

            // Rules list
            Rectangle {
                background: Palette.alternate-background;
                border-radius: 6px;
                border-width: 1px;
                border-color: Palette.border;
                horizontal-stretch: 1;
                VerticalLayout {
                    Rectangle {
                        height: 28px;
                        background: Palette.control-background;
                        border-radius: 6px;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 4px;
                            Text { horizontal-stretch: 1; text: Translations.tree_view_bottom_tool_type; vertical-alignment: center; font-weight: 700; }
                            Text { horizontal-stretch: 1; text: Translations.tree_view_bottom_usage_name; vertical-alignment: center; font-weight: 700; }
                            Text { horizontal-stretch: 2; text: Translations.tree_view_bottom_description; vertical-alignment: center; font-weight: 700; }
                        }
                    }
                    ListView {
                        vertical-stretch: 1;
                        for row[idx] in root.rules : Rectangle {
                            height: 26px;
                            background: row.selected ? Palette.accent-background : (mod(idx, 2) == 0 ? Palette.alternate-background : Palette.background);
                            TouchArea {
                                double-clicked => { Callabler.open-rule-editor(idx); }
                                pointer-event(event) => {
                                    if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                                        if event.modifiers.control {
                                            GuiState.last_rule_anchor_idx = idx;
                                            Callabler.rule-row-click-toggle(idx);
                                        } else if event.modifiers.shift {
                                            if GuiState.last_rule_anchor_idx == -1 {
                                                GuiState.last_rule_anchor_idx = idx;
                                            }
                                            Callabler.rule-row-click-range(GuiState.last_rule_anchor_idx, idx);
                                        } else {
                                            GuiState.last_rule_anchor_idx = idx;
                                            Callabler.rule-row-click-select(idx);
                                        }
                                    }
                                }
                            }
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 4px;
                                Text { horizontal-stretch: 1; min-width: 0px; text: row.rule_type_text; vertical-alignment: center; color: row.selected ? Palette.accent-foreground : Palette.foreground; overflow: elide; }
                                Text { horizontal-stretch: 1; min-width: 0px; text: row.usage_text; vertical-alignment: center; color: row.selected ? Palette.accent-foreground : Palette.foreground; overflow: elide; }
                                Text { horizontal-stretch: 2; min-width: 0px; text: row.description; vertical-alignment: center; color: row.selected ? Palette.accent-foreground : Palette.foreground; overflow: elide; }
                            }
                        }
                    }
                }
            }
        }
    }

    // Rule editor overlay (single instance held inside main window)
    if GuiState.rule_editor_open : Rectangle {
        background: #00000099;
        TouchArea { clicked => {} } // swallow clicks
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 780px;
            height: 660px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            RuleEditorPanel {
                width: 100%;
                height: 100%;
            }
        }
    }

    // Select popup
    if GuiState.select_popup_open : Rectangle {
        background: #00000077;
        TouchArea { clicked => { GuiState.select_popup_open = false; } }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 280px;
            height: 280px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            TouchArea { clicked => {} }
            VerticalLayout {
                padding: 8px;
                spacing: 4px;
                Button { text: Translations.button_select_all; clicked => { Callabler.select-action(SelectMode.select-all); GuiState.select_popup_open = false; } }
                Button { text: Translations.button_unselect_all; clicked => { Callabler.select-action(SelectMode.unselect-all); GuiState.select_popup_open = false; } }
                Button { text: Translations.button_select_reverse; clicked => { Callabler.select-action(SelectMode.reverse); GuiState.select_popup_open = false; } }
                Button { text: Translations.button_select_custom; clicked => { GuiState.select_popup_open = false; GuiState.select_custom_dialog_open = true; } }
                Button { text: Translations.button_select_changed; clicked => { Callabler.select-action(SelectMode.select-changed); GuiState.select_popup_open = false; } }
                Button { text: Translations.button_unselect_changed; clicked => { Callabler.select-action(SelectMode.unselect-changed); GuiState.select_popup_open = false; } }
            }
        }
    }

    // Saved rule sets popup
    if GuiState.load_popup_open : Rectangle {
        background: #00000077;
        TouchArea { clicked => { GuiState.load_popup_open = false; } }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 360px;
            height: 360px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            TouchArea { clicked => {} }
            VerticalLayout {
                padding: 8px;
                spacing: 4px;
                Text { text: "Saved rule sets:"; font-weight: 700; }
                ListView {
                    vertical-stretch: 1;
                    for entry[idx] in Callabler.saved_rule_sets : Rectangle {
                        height: 32px;
                        HorizontalLayout {
                            padding: 2px;
                            spacing: 4px;
                            Text { text: entry.name; vertical-alignment: center; horizontal-stretch: 1; }
                            Button { text: "Load"; clicked => { Callabler.rule-set-load(idx); GuiState.load_popup_open = false; } }
                            Button { text: "X"; clicked => { Callabler.rule-set-delete(idx); } }
                        }
                    }
                }
                Button { text: Translations.dialog_button_cancel; clicked => { GuiState.load_popup_open = false; } }
            }
        }
    }

    // Settings overlay
    if GuiState.settings_open : Rectangle {
        background: #00000099;
        TouchArea { clicked => { GuiState.settings_open = false; } }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 480px;
            height: 460px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            TouchArea { clicked => {} }
            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                Text { text: "Settings"; font-weight: 700; font-size: 18px; }
                CheckBox {
                    text: Translations.check_button_dark_theme;
                    checked: Settings.dark_theme;
                    toggled => {
                        Settings.dark_theme = self.checked;
                        Palette.color-scheme = self.checked ? ColorScheme.dark : ColorScheme.light;
                        Callabler.set-dark-theme(self.checked);
                    }
                }
                HorizontalLayout {
                    spacing: 6px;
                    Text { text: Translations.settings_language_label; vertical-alignment: center; }
                    ComboBox {
                        horizontal-stretch: 1;
                        model: Settings.available_languages;
                        current-value: Settings.selected_language;
                        selected(v) => {
                            Settings.selected_language = v;
                            Callabler.set-language(v);
                        }
                    }
                }
                Button { text: Translations.settings_open_rules; clicked => { Callabler.open-rules-file(); } }
                Button { text: Translations.settings_open_cache_custom_texts; clicked => { Callabler.open-custom-texts-file(); } }
                Button { text: Translations.settings_open_config_dir; clicked => { Callabler.open-config-dir(); } }
                Button { text: Translations.settings_open_log_folder; clicked => { Callabler.open-log-folder(); } }
                Rectangle { vertical-stretch: 1; }
                Button { text: Translations.dialog_button_ok; clicked => { GuiState.settings_open = false; } }
            }
        }
    }

    // Add files dialog
    // Add folders dialog
    if GuiState.add_folders_dialog_open : Rectangle {
        background: #00000099;
        TouchArea { clicked => { GuiState.add_folders_dialog_open = false; } }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 520px;
            height: 380px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            TouchArea { clicked => {} }
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                Text { text: Translations.dialog_name_folders_to_include; font-weight: 700; }
                Rectangle {
                    background: Palette.alternate-background;
                    border-radius: 4px;
                    vertical-stretch: 1;
                    ListView {
                        for p in GuiState.add_folder_picked_paths : Rectangle {
                            height: 22px;
                            HorizontalLayout {
                                padding-left: 6px;
                                padding-right: 6px;
                                Text { text: p; vertical-alignment: center; overflow: elide; }
                            }
                        }
                    }
                }
                CheckBox {
                    text: Translations.dialog_scan_inside;
                    checked: GuiState.add_folder_scan_inside;
                    toggled => { GuiState.add_folder_scan_inside = self.checked; }
                }
                CheckBox {
                    text: Translations.dialog_ignore_folders;
                    checked: GuiState.add_folder_ignore_folders;
                    toggled => { GuiState.add_folder_ignore_folders = self.checked; }
                }
                HorizontalLayout {
                    spacing: 6px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: Translations.dialog_button_ok;
                        primary: true;
                        clicked => { GuiState.add_folders_dialog_open = false; Callabler.confirm-add-folders(GuiState.add_folder_scan_inside, GuiState.add_folder_ignore_folders); }
                    }
                    Button { text: Translations.dialog_button_cancel; clicked => { GuiState.add_folders_dialog_open = false; } }
                }
            }
        }
    }

    // Save rule set dialog
    if GuiState.save_rule_dialog_open : Rectangle {
        background: #00000099;
        TouchArea { clicked => { GuiState.save_rule_dialog_open = false; } }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 380px;
            height: 200px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            TouchArea { clicked => {} }
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                Text { text: Translations.dialog_save_rule; font-weight: 700; }
                Text { text: Translations.edit_names_choose_name; wrap: word-wrap; }
                LineEdit {
                    placeholder-text: "Rule name";
                    text <=> GuiState.save_rule_name;
                }
                if GuiState.existing_rule_set_names != "" : Text {
                    text: GuiState.existing_rule_set_names;
                    wrap: word-wrap;
                    font-italic: true;
                }
                Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    spacing: 6px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: Translations.dialog_button_ok;
                        primary: true;
                        enabled: GuiState.save_rule_name != "";
                        clicked => { GuiState.save_rule_dialog_open = false; Callabler.rule-set-save(GuiState.save_rule_name); }
                    }
                    Button { text: Translations.dialog_button_cancel; clicked => { GuiState.save_rule_dialog_open = false; } }
                }
            }
        }
    }

    // Select custom dialog
    if GuiState.select_custom_dialog_open : Rectangle {
        background: #00000099;
        TouchArea { clicked => { GuiState.select_custom_dialog_open = false; } }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 440px;
            height: 320px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            TouchArea { clicked => {} }
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                Text { text: Translations.dialog_select_custom; font-weight: 700; }
                Text { text: "Usage: */folder*/* or name-version-*.txt"; }
                LineEdit {
                    placeholder-text: "Pattern";
                    text <=> GuiState.select_custom_text;
                }
                CheckBox {
                    text: "Include directories";
                    checked: GuiState.select_custom_select_dirs;
                    toggled => { GuiState.select_custom_select_dirs = self.checked; }
                }
                ComboBox {
                    model: ["Path", "Current Name", "Future Name", "Path + Current Name", "Path + Future Name", "Directory / File"];
                    current-index <=> GuiState.select_custom_mode_index;
                }
                if GuiState.select_custom_mode_index == 5 : Text {
                    text: "When Directory / File mode is active, pattern is ignored - toggle 'Include directories' to choose dirs vs files.";
                    wrap: word-wrap;
                    font-italic: true;
                }
                Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    spacing: 6px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: "Select";
                        primary: true;
                        clicked => {
                            GuiState.select_custom_dialog_open = false;
                            Callabler.select-custom-apply(GuiState.select_custom_text, GuiState.select_custom_select_dirs, GuiState.select_custom_mode_index, true);
                        }
                    }
                    Button {
                        text: "Unselect";
                        clicked => {
                            GuiState.select_custom_dialog_open = false;
                            Callabler.select-custom-apply(GuiState.select_custom_text, GuiState.select_custom_select_dirs, GuiState.select_custom_mode_index, false);
                        }
                    }
                    Button { text: Translations.dialog_button_cancel; clicked => { GuiState.select_custom_dialog_open = false; } }
                }
            }
        }
    }

    // Outdated results warning
    if GuiState.outdated_warning_open : Rectangle {
        background: #00000099;
        TouchArea { clicked => {} }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 440px;
            height: 200px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                Text { text: Translations.dialog_outdated_results; font-weight: 700; }
                Text { text: Translations.renaming_some_records_not_updated; wrap: word-wrap; }
                Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    spacing: 6px;
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: Translations.dialog_button_ok; primary: true; clicked => { GuiState.outdated_warning_open = false; GuiState.confirm_dialog_open = true; } }
                    Button { text: Translations.dialog_button_cancel; clicked => { GuiState.outdated_warning_open = false; } }
                }
            }
        }
    }

    // Confirm renaming
    if GuiState.confirm_dialog_open : Rectangle {
        background: #00000099;
        TouchArea { clicked => {} }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 400px;
            height: 180px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                Text { text: Translations.dialog_confirm_renaming; font-weight: 700; }
                Text { text: "Are you sure that you want to rename " + GuiState.file_count + " files?"; wrap: word-wrap; }
                Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    spacing: 6px;
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: Translations.dialog_button_ok; primary: true; clicked => { GuiState.confirm_dialog_open = false; Callabler.confirm-renaming(); } }
                    Button { text: Translations.dialog_button_cancel; clicked => { GuiState.confirm_dialog_open = false; } }
                }
            }
        }
    }

    // Results dialog
    if GuiState.results_dialog_open : Rectangle {
        background: #00000099;
        TouchArea { clicked => {} }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            // Compact when there are no errors, large when an error list is shown.
            width: GuiState.failed_total > 0 ? 660px : 380px;
            height: GuiState.failed_total > 0 ? 460px : 190px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            VerticalLayout {
                padding: 14px;
                spacing: 6px;
                Text { text: Translations.dialog_results_of_renaming; font-weight: 700; }
                Text { text: "Properly renamed: " + GuiState.properly_renamed; }
                Text { text: "Ignored: " + GuiState.ignored_count; }
                if GuiState.failed_total > 0 : Text {
                    text: "Errors: " + GuiState.failed_total;
                    font-weight: 700;
                    color: red;
                }
                if GuiState.failed_total > 0 : Rectangle {
                    background: Palette.alternate-background;
                    border-radius: 4px;
                    vertical-stretch: 1;
                    ScrollView {
                        VerticalLayout {
                            padding: 6px;
                            Text { text: GuiState.failed_text; wrap: word-wrap; }
                        }
                    }
                }
                if GuiState.failed_pages > 1 : HorizontalLayout {
                    spacing: 6px;
                    alignment: center;
                    Button {
                        text: "◀";
                        enabled: GuiState.failed_page > 0;
                        clicked => { Callabler.results-set-page(GuiState.failed_page - 1); }
                    }
                    Text {
                        text: "Page " + (GuiState.failed_page + 1) + " / " + GuiState.failed_pages;
                        vertical-alignment: center;
                    }
                    Button {
                        text: "▶";
                        enabled: GuiState.failed_page < GuiState.failed_pages - 1;
                        clicked => { Callabler.results-set-page(GuiState.failed_page + 1); }
                    }
                }
                // Keep the OK button pinned to the bottom when there is no error list to stretch.
                if GuiState.failed_total == 0 : Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    spacing: 6px;
                    if GuiState.failed_total > 0 : Button {
                        text: "Copy all errors";
                        clicked => { Callabler.results-copy-errors(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: Translations.dialog_button_ok; clicked => { GuiState.results_dialog_open = false; } }
                }
            }
        }
    }

    // Generic message dialog
    if GuiState.message_dialog_open : Rectangle {
        background: #00000099;
        TouchArea { clicked => {} }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 360px;
            height: 180px;
            background: Palette.background;
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.border;
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                Text { text: GuiState.message_dialog_title; font-weight: 700; }
                Text { text: GuiState.message_dialog_text; wrap: word-wrap; }
                Rectangle { vertical-stretch: 1; }
                HorizontalLayout {
                    Rectangle { horizontal-stretch: 1; }
                    Button { text: Translations.dialog_button_ok; clicked => { GuiState.message_dialog_open = false; } }
                }
            }
        }
    }

    // Progress overlay - blocks everything, no cancel
    if ProgressState.visible : Rectangle {
        background: #000000cc;
        // Swallow clicks so nothing underneath receives them
        TouchArea {
            clicked => {}
            pointer-event(_) => {}
        }
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 480px;
            height: 200px;
            background: Palette.background;
            border-radius: 10px;
            border-width: 1px;
            border-color: Palette.border;
            TouchArea {}
            VerticalLayout {
                padding: 20px;
                spacing: 12px;
                Text {
                    text: ProgressState.title;
                    font-weight: 700;
                    font-size: 18px;
                }
                Text {
                    text: ProgressState.message;
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                }
                Rectangle { vertical-stretch: 1; }
                // Progress bar (only when we know total)
                if !ProgressState.indeterminate : Rectangle {
                    height: 18px;
                    background: Palette.alternate-background;
                    border-radius: 4px;
                    Rectangle {
                        x: 0;
                        y: 0;
                        height: parent.height;
                        width: ProgressState.total > 0
                            ? parent.width * (ProgressState.current / ProgressState.total)
                            : 0px;
                        background: Palette.accent-background;
                        border-radius: 4px;
                    }
                }
                if ProgressState.indeterminate : Text {
                    text: "Working…";
                    horizontal-alignment: center;
                    color: Palette.foreground;
                }
                if !ProgressState.indeterminate : Text {
                    text: ProgressState.current + " / " + ProgressState.total;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
